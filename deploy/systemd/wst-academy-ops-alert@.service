[Unit]
Description=WST operational failure alert for %i
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/wst-academy-qabul-bot
ExecStart=/usr/bin/node /opt/wst-academy-qabul-bot/scripts/notify-systemd-failure.mjs %i
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/opt/wst-academy-qabul-bot/data
