# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs that can use admin commands and receive lead notifications
ADMIN_IDS=

# Optional: change where leads are stored. Defaults to ./data/leads.json
LEADS_FILE=./data/leads.json

# Optional: send completed leads to n8n or another webhook endpoint. Leave empty to disable.
LEAD_WEBHOOK_URL=

# Optional: set production in deployment
NODE_ENV=production
