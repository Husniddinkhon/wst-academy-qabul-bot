# Telegram bot token from @BotFather
BOT_TOKEN=
BOT_DESCRIPTION="WST Academy videokuzatuv kursi: 1 oy, 12 dars, offline real uskunalarda amaliyot. Manzil: Toshkent shahri, Arnasoy ko‘chasi, 33-uy. Keyingi guruh 2026-yil 4-avgustga rejalashtirilgan; qabulga qarab 1–2 kun siljishi mumkin. Darslar 10:00–16:00 oralig‘ida, kunlar guruh talabiga qarab belgilanadi."
COURSE_LOCATION=Toshkent shahri, Arnasoy ko‘chasi, 33-uy
COURSE_START_DATE=2026-08-04
CHANNEL_CHAT_ID=-1004297032922
# Optional: linked discussion group where product-sales questions are handled.
SALES_DISCUSSION_CHAT_ID=
CHANNEL_POSTS_FILE=./data/channel_posts.json
OPS_ALERTS_FILE=./data/ops_alerts.json
OPS_AGGREGATE_PORT=8381
OPS_AGGREGATE_SERVICE_ID=wst-academy-qabul-bot
OPS_AGGREGATE_SECRET=replace-with-a-unique-secret-at-least-32-characters
CHANNEL_SCHEDULER_ENABLED=true
CHANNEL_SCHEDULER_POLL_MS=30000
# Token-owned claim lease. CHANNEL_PUBLISH_STALE_MS remains a backward-compatible alias.
CHANNEL_CLAIM_LEASE_MS=600000
CHANNEL_CLAIM_RENEW_MS=120000
# Unknown sends remain fail-closed; after this window they require manual review.
CHANNEL_UNCERTAIN_WINDOW_MS=86400000
# SIGTERM/SIGINT bounded drain for publisher and scheduler work.
SHUTDOWN_DRAIN_TIMEOUT_MS=30000
# Local image files must stay inside this root. HTTPS images are disabled unless
# their exact host is listed in CHANNEL_IMAGE_HOSTS.
CHANNEL_ASSET_ROOT=./assets/channel
CHANNEL_IMAGE_HOSTS=

# Time-bounded product campaign. The bot stops matching and creating campaign
# leads outside this inclusive Asia/Tashkent date range.
UNV_BRAND=UNV
UNV_MODEL=Uho-P1G-M3F4D-EU
UNV_CAMPAIGN_ID=unv_uho_p1g_m3f4d_eu_202607
UNV_PROMOTION_START_DATE=2026-07-13
UNV_PROMOTION_END_DATE=2026-07-20
UNV_PROMO_PRICE_UZS=499000
UNV_REGULAR_PRICE_UZS=526350
UNV_WARRANTY_MONTHS=12

# Comma-separated Telegram user IDs that can use admin commands and receive lead notifications
ADMIN_IDS=

# Operator Telegram username shown to users
OPERATOR_USERNAME=@hr_wst

# Operator phone number shown to users
OPERATOR_PHONE=+998333011511

# Optional: change where local JSON data is stored
LEADS_FILE=./data/leads.json
WEBHOOK_FAILED_FILE=./data/webhook_failed.json
FOLLOWUPS_FILE=./data/followups.json
FOLLOWUP_CLAIM_LEASE_MS=300000
FOLLOWUP_MAX_ATTEMPTS=3
FOLLOWUP_RETRY_BASE_MS=300000
FOLLOWUP_RETRY_MAX_MS=3600000
# Durable replay journal and Telegraf session state. Keep these on the same
# private durable filesystem as the other bot JSON stores.
TELEGRAM_UPDATES_FILE=./data/telegram_updates.json
# Lease timestamp is diagnostic; a live owner is never preempted. Dead owners
# are recovered from the durable raw update. Terminal IDs are retained for seven
# days subject to this count bound; size it above seven days of update volume.
TELEGRAM_UPDATE_LEASE_MS=300000
TELEGRAM_UPDATE_RETENTION=100000

# Optional: send completed leads to n8n or another webhook endpoint. Leave empty to disable.
LEAD_WEBHOOK_URL=

# Optional Academy mode: set both values to sign Academy-compatible lead payloads.
# The service ID must match ACADEMY_BOT_SERVICE_ID on the Academy API.
LEAD_WEBHOOK_SERVICE_ID=
LEAD_WEBHOOK_SECRET=

# Aggregate-only Academy KPI API. Reuses the service ID/secret above; never configure database credentials in this bot.
ACADEMY_REPORT_BASE_URL=https://pilot.montag.uz/academy-api
ACADEMY_REPORT_TIMEOUT_MS=5000
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR=21

# Optional: set production in deployment
NODE_ENV=production

# Optional: AI sales sub-agent (OpenAI-compatible chat completions API)
AI_ENABLED=false
AI_PROVIDER=openai_compatible
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TEMPERATURE=0.3
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_OUTPUT_TOKENS=300
AI_MAX_OUTPUT_TOKENS_ENABLED=true

# Per-user cost protection and bounded provider circuit breaker.
AI_RATE_LIMIT_MAX_REQUESTS=6
AI_RATE_LIMIT_WINDOW_MS=60000
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_BASE_BACKOFF_MS=30000
AI_CIRCUIT_MAX_BACKOFF_MS=300000

# Optional: second OpenAI-compatible provider used only when the primary fails.
# Configure all three required values together or leave all of them empty.
AI_FALLBACK_API_KEY=
AI_FALLBACK_BASE_URL=
AI_FALLBACK_MODEL=
AI_FALLBACK_TEMPERATURE=0.3
AI_FALLBACK_REQUEST_TIMEOUT_MS=15000
AI_FALLBACK_MAX_OUTPUT_TOKENS=300
AI_FALLBACK_MAX_OUTPUT_TOKENS_ENABLED=true
