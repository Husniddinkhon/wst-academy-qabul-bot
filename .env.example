# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs that can use admin commands and receive lead notifications
ADMIN_IDS=

# Operator Telegram username shown to users
OPERATOR_USERNAME=@hr_wst

# Operator phone number shown to users
OPERATOR_PHONE=+998333011511

# Optional: change where leads are stored. Defaults to ./data/leads.json
LEADS_FILE=./data/leads.json

# Optional: send completed leads to n8n or another webhook endpoint. Leave empty to disable.
LEAD_WEBHOOK_URL=

# Optional: set production in deployment
NODE_ENV=production

# Optional: AI sales sub-agent (OpenAI-compatible chat completions API)
AI_ENABLED=false
AI_PROVIDER=openai_compatible
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TEMPERATURE=0.3
